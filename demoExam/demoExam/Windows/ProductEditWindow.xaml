<Window x:Class="demoExam.Windows.ProductEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Редактирование товара" Height="750" Width="600" WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> 
            <RowDefinition Height="*"/>    
            <RowDefinition Height="Auto"/> 
        </Grid.RowDefinitions>

        <TextBlock Text="Товар" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Image x:Name="ProductImage" Width="140" Height="140" Stretch="Uniform" HorizontalAlignment="Left" Margin="0,0,10,0"
                           Source="pack://application:,,,/Resource/Icons/picture.png"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <Button x:Name="ChangeImageButton" Content="Изменить изображение" Padding="5" Margin="0,0,0,5" Click="ChangeImageButton_Click"/>
                        <TextBlock Text="Макс. размер 300x200" FontSize="10" Foreground="Gray"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="ID товара (только чтение):"/>
                <TextBox x:Name="IdTextBox" IsReadOnly="True" Background="#F0F0F0" Margin="0,0,0,10"/>

                <TextBlock Text="Наименование:"/>
                <TextBox x:Name="NameTextBox" Margin="0,0,0,10"/>

                <TextBlock Text="Категория:"/>
                <ComboBox x:Name="CategoryComboBox" DisplayMemberPath="Name" SelectedValuePath="Id" Margin="0,0,0,10"/>

                <TextBlock Text="Описание:"/>
                <TextBox x:Name="DescriptionTextBox" TextWrapping="Wrap" Height="60" AcceptsReturn="True" Margin="0,0,0,10"/>

                <TextBlock Text="Производитель:"/>
                <ComboBox x:Name="ManufacturerComboBox" DisplayMemberPath="Name" SelectedValuePath="Id" Margin="0,0,0,10"/>

                <TextBlock Text="Поставщик:"/>
                <ComboBox x:Name="SupplierComboBox" DisplayMemberPath="Name" SelectedValuePath="Id" Margin="0,0,0,10"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" Margin="0,0,5,0">
                        <TextBlock Text="Цена:"/>
                        <TextBox x:Name="PriceTextBox" Margin="0,0,0,10" PreviewTextInput="NumberValidationTextBox"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="1" Margin="5,0,0,0">
                         <TextBlock Text="Скидка (%):"/>
                         <TextBox x:Name="DiscountTextBox" Margin="0,0,0,10" PreviewTextInput="NumberValidationTextBox"/>
                    </StackPanel>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" Margin="0,0,5,0">
                         <TextBlock Text="Единица измерения:"/>
                         <TextBox x:Name="UnitTextBox" Margin="0,0,0,10" Text="шт."/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="5,0,0,0">
                        <TextBlock Text="Количество на складе:"/>
                        <TextBox x:Name="StockCountTextBox" Margin="0,0,0,10" PreviewTextInput="NumberValidationTextBox"/>
                    </StackPanel>
                </Grid>

            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
             <Button x:Name="DeleteButton" Content="Удалить товар" Background="#FFCCCC" BorderBrush="Red" Margin="0,0,20,0" Padding="10,5" Click="DeleteButton_Click" Visibility="Collapsed"/>
             <Button x:Name="SaveButton" Content="Сохранить" Padding="20,5" Click="SaveButton_Click"/>
             <Button Content="Отмена" Padding="20,5" Margin="10,0,0,0" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
