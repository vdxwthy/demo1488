<Window x:Class="demoExam.Windows.OrderEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Заказ"
        Height="360"
        Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="170"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,10,10" VerticalAlignment="Center" Text="Артикул:"/>
        <TextBox x:Name="CodeTextBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,10,10" VerticalAlignment="Center" Text="Статус заказа:"/>
        <ComboBox x:Name="StatusComboBox" Grid.Row="1" Grid.Column="1" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,10,10" VerticalAlignment="Center" Text="Адрес пункта выдачи:"/>
        <ComboBox x:Name="PickupPointComboBox"
                  Grid.Row="2"
                  Grid.Column="1"
                  Margin="0,0,0,10"
                  DisplayMemberPath="Address"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,0,10,10" VerticalAlignment="Center" Text="Дата заказа:"/>
        <DatePicker x:Name="DateOrderPicker" Grid.Row="3" Grid.Column="1" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,0,10,10" VerticalAlignment="Center" Text="Дата выдачи:"/>
        <DatePicker x:Name="DateDeliveryPicker" Grid.Row="4" Grid.Column="1" Margin="0,0,0,10"/>

        <TextBlock x:Name="ErrorTextBlock"
                   Grid.Row="5"
                   Grid.ColumnSpan="2"
                   Margin="0,0,0,10"
                   Foreground="Red"
                   TextWrapping="Wrap"/>

        <StackPanel Grid.Row="6" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Сохранить" Width="100" Margin="0,0,10,0" Click="SaveButton_Click"/>
            <Button Content="Отмена" Width="100" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
